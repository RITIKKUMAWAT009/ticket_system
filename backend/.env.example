# Server
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# Database (Supabase PostgreSQL for production)
DATABASE_URL=postgresql://YOUR_USER@localhost:5432/ticket_db?schema=public
# Docker Compose uses: postgresql://postgres:postgres@localhost:5432/ticket_db?schema=public
# Homebrew PostgreSQL (macOS): postgresql://$(whoami)@localhost:5432/ticket_db?schema=public

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# OTP
OTP_EXPIRY_MINUTES=5
OTP_LENGTH=6

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=2

# Firebase Cloud Messaging
# Path to service account JSON or base64-encoded JSON
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Set to true to skip FCM in development
FCM_DISABLED=true

# CORS
CORS_ORIGIN=http://localhost:8080,http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Captcha (simple server-side captcha for MVP)
CAPTCHA_EXPIRY_MINUTES=10
